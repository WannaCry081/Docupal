# Make sure everyone gets the same line endings (LF) when they clone this repo
* text=auto eol=lf

# Text files
*.md        text
*.yaml      text
*.yml       text
*.json      text
*.toml      text
*.sh        text eol=lf
Makefile    text

# Binary files — git should not try to diff or merge these
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.pdf       binary
*.zip       binary
*.tar.gz    binary
*.woff      binary
*.woff2     binary

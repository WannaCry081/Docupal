# EditorConfig helps keep code style consistent across different editors.
# Learn more: https://editorconfig.org
root = true

[*]
charset               = utf-8
end_of_line           = lf
insert_final_newline  = true
trim_trailing_whitespace = true
indent_style          = space
indent_size           = 2

[Makefile]
# Makefiles require real tab characters — do not change this
indent_style = tab

[*.md]
# Two trailing spaces = intentional line break in Markdown
trim_trailing_whitespace = false
